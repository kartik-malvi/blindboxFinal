{
  "name": "shopline-blind-box",
  "version": "1.0.0",
  "description": "Blind Box app for Shopline — random mystery product assignment",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc --project tsconfig.json",
    "build:widget": "cd storefront-src && npx rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript --bundleConfigAsCjs",
    "build:admin": "cd admin && npm run build",
    "build:all": "npm run build && npm run build:widget && npm run build:admin",
    "start": "node dist/server.js",
    "migrate": "npx prisma migrate dev",
    "migrate:prod": "npx prisma migrate deploy",
    "test": "jest --runInBand --forceExit",
    "push:ext": "cd theme-app-extension && sl extension push"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@sentry/node": "^7.100.0",
    "bullmq": "^5.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.4",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "ioredis": "^5.3.2",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.20",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "prisma": "^5.10.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  },
  "jest": {
    "projects": [
      {
        "displayName": "backend",
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testMatch": [
          "**/tests/itemSelector.test.ts",
          "**/tests/webhook.test.ts"
        ],
        "setupFiles": [
          "dotenv/config"
        ],
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest",
            {
              "tsconfig": "tsconfig.json"
            }
          ]
        }
      },
      {
        "displayName": "widget",
        "preset": "ts-jest",
        "testEnvironment": "jsdom",
        "testMatch": [
          "**/tests/widget.test.ts"
        ],
        "setupFiles": [
          "dotenv/config"
        ],
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest",
            {
              "tsconfig": "tests/tsconfig.json"
            }
          ]
        }
      }
    ]
  }
}
